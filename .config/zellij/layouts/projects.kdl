// Project workspace layout — shell panes that survive restart
// Each tab opens a shell in the project directory.
// Type 'claude' to start Claude Code in any tab.

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="Revamp-Info" {
        pane cwd="/home/g/dev/revamp-info"
    }
    tab name="Revamp-IT" {
        pane cwd="/home/g/dev/revampit"
    }
    tab name="AOZ" {
        pane cwd="/home/g/dev/aoz-housing"
    }
    tab name="OC" {
        pane cwd="/home/g/dev/orangecat"
    }
    tab name="Kivvi" {
        pane cwd="/home/g/dev/kivvi"
    }
    tab name="OpenClaw" {
        pane cwd="/home/g/dev/openclaw"
    }
    tab name="Scratch" focus=true {
        pane cwd="/home/g"
    }
}
